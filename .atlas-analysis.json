  "keyFeatures": [
    "Domain fronting via Google Apps Script — makes traffic appear as Google traffic to DPI",
    "Cloudflare Worker exit node for fetching real destination URLs",
    "Local HTTP and SOCKS5 proxy with MITM TLS interception",
    "SNI rewriting to bypass blocked hostnames (YouTube, etc.)",
    "Parallel batch relay for high throughput",
    "Chunked download support for large files",
    "LAN sharing mode to share the proxy with other devices",
    "Interactive setup wizard for first-time configuration",
    "Google IP scanner to find fastest reachable frontend IP",
    "Response cache for static assets"
  ],
  "publicApiSurface": [
    "main.py -- entry point, CLI arguments: -c/--config, -p/--port, --host, --socks5-port, --disable-socks5, --log-level, --install-cert, --uninstall-cert, --no-cert-check, --scan",
    "setup.py -- interactive configuration wizard",
    "config.json -- runtime configuration file (see config.example.json)",
    "script/Code.gs -- Google Apps Script relay (doPost, doGet)",
    "script/worker.js -- Cloudflare Worker exit node (fetch handler)",
    "ProxyServer -- async HTTP+SOCKS5 proxy server class",
    "DomainFronter -- domain fronting relay engine",
    "MITMCertManager -- TLS certificate manager for MITM interception"
  ]
}
